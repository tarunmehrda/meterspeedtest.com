---
import Logo from './Logo.astro';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container-page footer__inner">
    <div class="footer__brand">
      <Logo />
      <p class="footer__tagline">
        A fast, private internet speed test. Nothing to install, no sign-up — your results stay in
        your browser.
      </p>
    </div>

    <div class="footer__cols">
      <div class="footer__col">
        <h2 class="footer__head">Test</h2>
        <a href="/#top" class="footer__link">Run a test</a>
        <a href="/#metrics" class="footer__link">Detailed results</a>
        <a href="/#insights" class="footer__link">Connection insights</a>
        <a href="/#history" class="footer__link">History</a>
      </div>
      <div class="footer__col">
        <h2 class="footer__head">Learn</h2>
        <a href="/#faq" class="footer__link">FAQ</a>
        <a href="/#faq" class="footer__link">Speed Test guide</a>
        <a href="/#faq" class="footer__link">What is bufferbloat?</a>
        <a href="/#faq" class="footer__link">How Meter measures</a>
      </div>
      <div class="footer__col">
        <h2 class="footer__head">Company</h2>
        <a href="/about" class="footer__link">About us</a>
        <a href="/contact" class="footer__link">Contact us</a>
        <a href="https://github.com" class="footer__link" target="_blank" rel="noopener noreferrer"
          >Source</a
        >
      </div>
      <div class="footer__col">
        <h2 class="footer__head">Legal</h2>
        <a href="/privacy" class="footer__link">Privacy Policy</a>
        <a href="/terms" class="footer__link">Terms &amp; Conditions</a>
      </div>
    </div>
  </div>

  <div class="container-page footer__bar">
    <span>© {year} Meter Speed Test</span>
    <nav class="footer__legal" aria-label="Legal">
      <a href="/privacy" class="footer__legal-link">Privacy</a>
      <a href="/terms" class="footer__legal-link">Terms</a>
      <a href="/contact" class="footer__legal-link">Contact</a>
    </nav>
    <span class="footer__mono">meterspeedtest.com</span>
  </div>
</footer>

<style>
  .footer {
    margin-top: 96px;
    border-top: 1px solid var(--hairline);
    background: var(--surface);
    padding-block: 56px 24px;
  }
  .footer__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .footer__tagline {
    margin-top: 14px;
    max-width: 34ch;
    color: var(--text-muted);
    font-size: 14px;
    line-height: 1.55;
    text-wrap: pretty;
  }
  .footer__cols {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px 20px;
  }
  .footer__head {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-faint);
    margin-bottom: 14px;
    font-weight: 400;
  }
  .footer__link {
    display: block;
    color: var(--text-muted);
    font-size: 14px;
    padding-block: 6px;
    transition: color 0.15s;
  }
  .footer__link:hover {
    color: var(--text);
  }
  .footer__bar {
    margin-top: 44px;
    padding-top: 24px;
    border-top: 1px solid var(--hairline);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    color: var(--text-faint);
    font-size: 13px;
  }
  .footer__legal {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .footer__legal-link {
    color: var(--text-faint);
    transition: color 0.15s;
  }
  .footer__legal-link:hover {
    color: var(--text);
  }
  .footer__mono {
    font-family: var(--font-mono);
  }

  @media (min-width: 620px) {
    .footer__cols {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  @media (min-width: 760px) {
    .footer__inner {
      grid-template-columns: 1fr 2.4fr;
      gap: 56px;
    }
  }
</style>
