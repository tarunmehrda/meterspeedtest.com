---
interface Props {
  size?: number;
  withWordmark?: boolean;
}
const { size = 28, withWordmark = true } = Astro.props;
---

<a href="/" class="logo" aria-label="Meter Speed Test — home">
  <img
    src="/icon.png"
    width={size}
    height={size}
    alt=""
    aria-hidden="true"
    class="logo__mark"
    decoding="async"
  />
  {withWordmark && <span class="logo__word">Meter</span>}
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--text);
    font-weight: 600;
    font-size: 16px;
    letter-spacing: -0.02em;
  }
  .logo__mark {
    display: block;
    flex: none;
    object-fit: contain;
  }
  .logo__word {
    line-height: 1;
  }
</style>
