---
interface Props {
  metric: string; // id suffix, e.g. "download"
  label: string;
  unit: string;
  hint?: string;
  accent?: string; // CSS color for the icon chip
  icon: 'download' | 'upload' | 'ping' | 'jitter' | 'loss' | 'loaded';
}
const { metric, label, unit, hint = 'Waiting…', accent = 'var(--text-faint)', icon } = Astro.props;

const paths: Record<Props['icon'], string> = {
  download: 'M12 4v11m0 0 4-4m-4 4-4-4M5 19h14',
  upload: 'M12 20V9m0 0 4 4m-4-4-4 4M5 5h14',
  ping: 'M4 12h3l2 6 4-14 2 8h5',
  jitter: 'M3 12h4l2-5 3 10 2-7 2 2h5',
  loss: 'M12 8v5m0 3h.01M4.5 19h15a1.5 1.5 0 0 0 1.3-2.25l-7.5-13a1.5 1.5 0 0 0-2.6 0l-7.5 13A1.5 1.5 0 0 0 4.5 19Z',
  loaded: 'M5 12a7 7 0 0 1 14 0M12 12l3.5-2M9 19h6',
};
---

<div class="metric" id={`metric-${metric}`}>
  <div class="metric__top">
    <span class="metric__icon" style={`color:${accent}`}>
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d={paths[icon]}
          stroke="currentColor"
          stroke-width="1.9"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </span>
    <span class="metric__label">{label}</span>
  </div>
  <div class="metric__value">
    <span id={`m-${metric}`} class="tnum" data-empty="true">—</span>
    <span class="metric__unit">{unit}</span>
  </div>
  <div class="metric__hint" id={`h-${metric}`}>{hint}</div>
</div>

<style>
  .metric {
    background: var(--surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-2);
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 0;
  }
  .metric__top {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .metric__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-sm);
    background: var(--surface-soft-2);
  }
  .metric__label {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-muted);
  }
  .metric__value {
    display: flex;
    align-items: baseline;
    gap: 5px;
  }
  .metric__value > .tnum {
    font-size: 30px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text);
    transition: color 0.3s;
  }
  .metric__value > .tnum[data-empty='true'] {
    color: var(--text-faint);
  }
  .metric__unit {
    font-size: 13px;
    color: var(--text-faint);
    font-weight: 500;
  }
  .metric__hint {
    font-size: 12.5px;
    color: var(--text-faint);
    line-height: 1.45;
    min-height: 18px;
    text-wrap: pretty;
  }
  /* Highlight the metric being actively measured. */
  .metric[data-active='true'] {
    box-shadow: var(--shadow-3), inset 0 0 0 1px var(--color-brand-blue);
  }
</style>
