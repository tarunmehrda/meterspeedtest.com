---
import Logo from './Logo.astro';
---

<header class="nav">
  <div class="container-page nav__inner">
    <Logo />

    <nav class="nav__links" aria-label="Primary">
      <a href="#metrics" class="nav__link">Results</a>
      <a href="#insights" class="nav__link">Insights</a>
      <a href="#history" class="nav__link">History</a>
      <a href="#faq" class="nav__link">FAQ</a>
    </nav>

    <div class="nav__actions">
      <button
        type="button"
        id="theme-toggle"
        class="nav__icon-btn"
        aria-label="Switch to dark theme"
        title="Toggle theme"
      >
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="1.8" />
          <path
            d="M12 2v2.5M12 19.5V22M4.2 4.2l1.8 1.8M18 18l1.8 1.8M2 12h2.5M19.5 12H22M4.2 19.8 6 18M18 6l1.8-1.8"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
          />
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.5 6.5 0 0 0 9.8 9.8Z"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linejoin="round"
          />
        </svg>
      </button>
      <a
        href="https://github.com"
        class="nav__link nav__link--hide-sm"
        target="_blank"
        rel="noopener noreferrer">About</a
      >
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--surface) 78%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--hairline);
  }
  .nav__inner {
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .nav__links {
    display: none;
    align-items: center;
    gap: 2px;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }
  .nav__link {
    display: inline-flex;
    align-items: center;
    height: 32px;
    padding-inline: 12px;
    border-radius: var(--radius-pill);
    color: var(--text-muted);
    font-size: 14px;
    transition: color 0.15s, background-color 0.15s;
  }
  .nav__link:hover {
    color: var(--text);
    background: var(--surface-soft-2);
  }
  .nav__actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .nav__icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-pill);
    color: var(--text-muted);
    cursor: pointer;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    transition: color 0.15s, background-color 0.15s;
  }
  .nav__icon-btn:hover {
    color: var(--text);
    background: var(--surface-soft-2);
  }
  .icon-moon {
    display: none;
  }
  :global([data-theme='dark']) .icon-sun {
    display: none;
  }
  :global([data-theme='dark']) .icon-moon {
    display: block;
  }

  @media (min-width: 860px) {
    .nav__links {
      display: flex;
    }
  }
  @media (max-width: 520px) {
    .nav__link--hide-sm {
      display: none;
    }
  }
</style>

<script>
  const btn = document.getElementById('theme-toggle');
  const root = document.documentElement;
  const lightMeta = document.getElementById('theme-color-light');
  const darkMeta = document.getElementById('theme-color-dark');

  function syncLabel() {
    const isDark = root.getAttribute('data-theme') === 'dark';
    btn?.setAttribute('aria-label', isDark ? 'Switch to light theme' : 'Switch to dark theme');
    // Keep the active theme-color authoritative regardless of OS preference.
    lightMeta?.setAttribute('media', isDark ? 'not all' : '(prefers-color-scheme: light)');
    darkMeta?.setAttribute('media', isDark ? 'all' : '(prefers-color-scheme: dark)');
  }

  btn?.addEventListener('click', () => {
    const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    try {
      localStorage.setItem('meter:theme', next);
    } catch {
      /* ignore */
    }
    syncLabel();
  });

  syncLabel();
</script>
