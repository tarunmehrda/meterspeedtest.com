---
import { GAUGE, arcPath, speedTicks, pointAt } from '../lib/gauge';

const ticks = speedTicks();
const path = arcPath();
const cx = GAUGE.cx;
const cy = GAUGE.cy;
---

<div class="gauge" data-gauge data-phase="idle" data-dial="rest">
  <!-- Decorative: the accessible readout is the live status region + metric cards. -->
  <svg class="gauge__svg" viewBox="0 0 320 320" aria-hidden="true">
    <defs>
      <linearGradient id="gaugeGrad" x1="0" y1="1" x2="1" y2="0">
        <stop offset="0%" class="arc-stop arc-stop--a" />
        <stop offset="45%" class="arc-stop arc-stop--b" />
        <stop offset="100%" class="arc-stop arc-stop--c" />
      </linearGradient>
      <linearGradient id="needleGrad" x1="0" y1="1" x2="0" y2="0">
        <stop offset="0%" stop-color="var(--text-faint)" stop-opacity="0.1" />
        <stop offset="30%" stop-color="var(--text)" stop-opacity="0.8" />
        <stop offset="100%" stop-color="var(--text)" stop-opacity="1" />
      </linearGradient>
      <filter id="gaugeGlow" x="-30%" y="-30%" width="160%" height="160%">
        <feGaussianBlur stdDeviation="4" result="b" />
        <feMerge>
          <feMergeNode in="b" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
      <filter id="needleShadow" x="-20%" y="-20%" width="140%" height="140%">
        <feDropShadow dx="1" dy="2" stdDeviation="2" flood-color="#000" flood-opacity="0.4"/>
      </filter>
    </defs>

    <!-- Track -->
    <path class="gauge__track" d={path} pathLength={GAUGE.pathLength} />

    <!-- Ticks -->
    <g class="gauge__ticks">
      {
        ticks.map((t) => (
          <line
            x1={t.inner.x.toFixed(2)}
            y1={t.inner.y.toFixed(2)}
            x2={t.outer.x.toFixed(2)}
            y2={t.outer.y.toFixed(2)}
            class={t.major ? 'tick tick--major' : 'tick'}
          />
        ))
      }
      {
        ticks
          .filter((t) => t.major)
          .map((t) => (
            <text
              x={t.labelPos.x.toFixed(2)}
              y={t.labelPos.y.toFixed(2)}
              class="tick__label"
              text-anchor="middle"
              dominant-baseline="middle"
            >
              {t.label}
            </text>
          ))
      }
    </g>

    <!-- Value arc (animated via stroke-dashoffset) -->
    <path
      id="gauge-arc"
      class="gauge__value-arc"
      d={path}
      pathLength={GAUGE.pathLength}
      stroke="url(#gaugeGrad)"
      filter="url(#gaugeGlow)"
    />

    <!-- Needle -->
    <g id="gauge-needle" transform={`rotate(-135 ${cx} ${cy})`}>
      <path
        class="gauge__needle"
        d={`M ${cx - 3.5} ${cy + 15} L ${cx - 1} ${cy - (GAUGE.r - 12)} A 1 1 0 0 1 ${cx + 1} ${cy - (GAUGE.r - 12)} L ${cx + 3.5} ${cy + 15} Z`}
        fill="url(#needleGrad)"
        filter="url(#needleShadow)"
      />
    </g>
    <circle class="gauge__hub-outer" cx={cx} cy={cy} r="14" />
    <circle class="gauge__hub-middle" cx={cx} cy={cy} r="8" fill="var(--surface)" stroke="var(--hairline-strong)" stroke-width="1.5" />
    <circle class="gauge__hub" cx={cx} cy={cy} r="4" fill="var(--text)" />
  </svg>

  <!-- Large circular GO button in the center when idle -->
  <button type="button" id="go-btn" class="go-btn" hidden>
    <span class="go-btn__text">GO</span>
  </button>

  <!-- Live readout positioned at the lower half of the dial -->
  <div class="gauge__readout" id="gauge-readout" hidden>
    <div class="gauge__value-wrap">
      <span id="gauge-value" class="tnum">0.00</span>
    </div>
    <div class="gauge__unit-wrap">
      <span id="gauge-phase-icon" class="gauge__phase-icon"></span>
      <span id="gauge-unit" class="gauge__unit">Mbps</span>
    </div>
  </div>
</div>

<style>
  .gauge {
    position: relative;
    isolation: isolate;
    width: min(100%, 360px);
    aspect-ratio: 1 / 1;
    margin-inline: auto;

    animation: gaugeFadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;

    /* Arc gradient per phase — morphs via stop-color transitions. */
    --arc-a: var(--color-cyan);
    --arc-b: var(--color-brand-blue);
    --arc-c: var(--color-violet);
    --glow: var(--color-brand-blue);
  }
  @keyframes gaugeFadeIn {
    from {
      opacity: 0;
      transform: scale(0.96) translateY(8px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }
  .gauge[data-phase='latency'] {
    --arc-a: var(--color-g-ship-end);
    --arc-b: var(--color-amber);
    --arc-c: var(--color-g-ship-start);
    --glow: var(--color-amber);
  }
  .gauge[data-phase='upload'] {
    --arc-a: var(--color-brand-blue);
    --arc-b: var(--color-violet);
    --arc-c: var(--color-pink);
    --glow: var(--color-violet);
  }

  /* GO Button styling */
  .go-btn {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 130px;
    height: 130px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--surface) 40%, var(--surface-soft-2) 100%);
    border: 3.5px solid var(--color-brand-blue);
    box-shadow: 0 0 28px rgba(0, 112, 243, 0.35), inset 0 0 16px rgba(0, 112, 243, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    transition:
      opacity 0.4s var(--ease-out-quint),
      transform 0.4s var(--ease-out-quint),
      border-color 0.35s var(--ease-out-quint),
      box-shadow 0.35s var(--ease-out-quint);
  }
  .go-btn:hover {
    transform: scale(1.08);
    border-color: var(--color-cyan);
    box-shadow: 0 0 38px rgba(80, 227, 194, 0.55), inset 0 0 22px rgba(80, 227, 194, 0.15);
  }
  .go-btn:active {
    transform: scale(0.96);
  }
  /* Gentle expanding-ring "tap me" invite. Sits on a pseudo-element so it never
     fights the button's own hover / hidden transforms. */
  .go-btn::after {
    content: '';
    position: absolute;
    inset: -3.5px;
    border-radius: 50%;
    border: 2px solid var(--color-brand-blue);
    opacity: 0;
    pointer-events: none;
    animation: goPulse 2.8s var(--ease-out-quint) infinite;
  }
  .go-btn:hover::after {
    animation-play-state: paused;
  }
  @keyframes goPulse {
    0% {
      transform: scale(1);
      opacity: 0.55;
    }
    70%,
    100% {
      transform: scale(1.3);
      opacity: 0;
    }
  }
  .go-btn__text {
    font-size: 34px;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: var(--text);
    transition: color 0.3s;
  }
  .go-btn:hover .go-btn__text {
    color: var(--color-cyan-deep);
  }
  .go-btn[hidden],
  .go-btn[hidden]:hover,
  .go-btn[hidden]:active {
    display: flex !important;
    opacity: 0;
    pointer-events: none;
    transform: scale(0.3) rotate(-15deg);
    box-shadow: none;
  }

  /* Soft breathing halo behind the dial while a test runs. */
  .gauge::before {
    content: '';
    position: absolute;
    inset: 6%;
    z-index: -1;
    border-radius: 50%;
    background: radial-gradient(
      closest-side,
      color-mix(in srgb, var(--glow) 16%, transparent),
      transparent 72%
    );
    opacity: 0;
    transition: opacity 0.5s var(--ease-out-quint), background 0.5s;
  }
  .gauge[data-state='running']::before {
    opacity: 1;
    animation: gaugeBreathe 2.4s ease-in-out infinite;
  }
  @keyframes gaugeBreathe {
    0%,
    100% {
      transform: scale(0.96);
      opacity: 0.65;
    }
    50% {
      transform: scale(1.04);
      opacity: 1;
    }
  }

  .gauge__svg {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .arc-stop {
    transition: stop-color 0.5s var(--ease-out-quint);
  }
  .arc-stop--a {
    stop-color: var(--arc-a);
  }
  .arc-stop--b {
    stop-color: var(--arc-b);
  }
  .arc-stop--c {
    stop-color: var(--arc-c);
  }

  .gauge__track {
    fill: none;
    stroke: var(--track);
    stroke-width: 14;
    stroke-linecap: round;
    /* Power-on: the ring traces itself into place on first paint. */
    stroke-dasharray: 1000;
    animation: trackDraw 1.15s var(--ease-out-quint) 0.12s both;
  }
  @keyframes trackDraw {
    from {
      stroke-dashoffset: 1000;
    }
    to {
      stroke-dashoffset: 0;
    }
  }
  .gauge__ticks {
    animation: gaugePartFade 0.9s ease 0.62s both;
  }
  @keyframes gaugePartFade {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  .gauge__value-arc {
    fill: none;
    stroke-width: 14;
    stroke-linecap: round;
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    /* Opacity-only transition: the dash offset is driven per-frame in JS and
       must stay instant, but the arc can fade in/out cleanly between states. */
    transition: opacity 0.5s var(--ease-out-quint);
  }

  .tick {
    stroke: var(--hairline-strong);
    stroke-width: 1.5;
    stroke-linecap: round;
  }
  .tick--major {
    stroke: var(--hairline-strongest);
    stroke-width: 2.2;
  }
  .tick__label {
    fill: var(--text-muted);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 11px;
  }

  #gauge-needle {
    transform-origin: 160px 160px;
    transform: rotate(-135deg);
    /* Opacity-only transition — the rotation is driven per-frame in JS. */
    transition: opacity 0.5s var(--ease-out-quint);
  }

  /* At rest (idle, after the power-on sweep) the needle and value arc fade
     away so the centred GO button reads cleanly, with nothing poking out. */
  .gauge[data-dial='rest'] #gauge-needle,
  .gauge[data-dial='rest'] .gauge__value-arc {
    opacity: 0;
  }
  .gauge__hub-outer {
    fill: var(--surface);
    stroke: var(--hairline-strong);
    stroke-width: 1.5;
  }

  /* Live Readout styling */
  .gauge__readout {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 23%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0px;
    pointer-events: none;
    z-index: 5;
    transition: opacity 0.7s var(--ease-out-quint);
  }
  .gauge__readout[hidden] {
    display: none !important;
  }
  /* At rest the readout sits dimmed beneath the GO button as a quiet "0.00". */
  .gauge__readout[data-idle] {
    opacity: 0.5;
  }
  .gauge__value-wrap {
    line-height: 1;
  }
  #gauge-value {
    font-size: 46px;
    font-weight: 300;
    font-family: var(--font-sans);
    letter-spacing: -0.02em;
    color: var(--text);
  }
  .gauge__unit-wrap {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: -2px;
  }
  .gauge__unit {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-faint);
  }

  /* Phase indicator icon (arrow in a circle) */
  .gauge__phase-icon {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .gauge__phase-icon::before {
    content: '';
    width: 0;
    height: 0;
    border-left: 3.5px solid transparent;
    border-right: 3.5px solid transparent;
    display: inline-block;
  }
  .gauge[data-phase='download'] .gauge__phase-icon {
    background-color: var(--color-cyan-deep);
  }
  .gauge[data-phase='download'] .gauge__phase-icon::before {
    border-top: 5px solid #fff;
    border-bottom: 0;
    margin-top: 1px;
  }
  .gauge[data-phase='upload'] .gauge__phase-icon {
    background-color: var(--color-brand-blue);
  }
  .gauge[data-phase='upload'] .gauge__phase-icon::before {
    border-bottom: 5px solid #fff;
    border-top: 0;
    margin-bottom: 1px;
  }

  @media (max-width: 380px) {
    #gauge-value {
      font-size: 40px;
    }
    .go-btn {
      width: 116px;
      height: 116px;
    }
    .go-btn__text {
      font-size: 30px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gauge::before {
      animation: none;
      transition: none;
    }
    .arc-stop {
      transition: none;
    }
  }
</style>
