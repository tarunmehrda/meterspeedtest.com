---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  /** Extra page-specific JSON-LD nodes (WebPage, FAQPage, BreadcrumbList, …). */
  schemas?: Record<string, unknown>[];
  /** Set true on utility pages (404) that should stay out of the index. */
  noindex?: boolean;
  /** Social share image, relative to the site root. */
  image?: string;
  imageAlt?: string;
}

const {
  title = 'Speed Test – Free Internet & WiFi Speed Test | Meter',
  description = 'Free online Speed Test. Check your internet speed in seconds — download, upload, ping, jitter, latency and packet loss for WiFi, broadband, fiber and mobile.',
  path = '/',
  schemas = [],
  noindex = false,
  image = '/og.svg',
  imageAlt = 'Meter Speed Test — internet speed test dashboard showing download, upload and ping.',
} = Astro.props;

const site = 'https://meterspeedtest.com';
const canonical = new URL(path, site).href;
const ogImage = new URL(image, site).href;
const robots = noindex
  ? 'noindex, follow'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';

// Stable @id anchors so page-level schemas can reference these site-wide nodes.
const orgId = `${site}/#organization`;
const siteId = `${site}/#website`;
const appId = `${site}/#app`;

// Site-wide structured data. Page components add WebPage / FAQPage /
// BreadcrumbList via the `schemas` prop; everything merges into one @graph.
const baseGraph: Record<string, unknown>[] = [
  {
    '@type': 'Organization',
    '@id': orgId,
    name: 'Meter Speed Test',
    url: site,
    logo: {
      '@type': 'ImageObject',
      url: new URL('/icon.png', site).href,
      width: 750,
      height: 750,
    },
  },
  {
    '@type': 'WebSite',
    '@id': siteId,
    url: site,
    name: 'Meter Speed Test',
    description:
      'Free internet Speed Test measuring download, upload, ping, jitter, latency and packet loss.',
    publisher: { '@id': orgId },
    inLanguage: 'en',
  },
  {
    '@type': 'SoftwareApplication',
    '@id': appId,
    name: 'Meter Speed Test',
    url: site,
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any (web browser)',
    browserRequirements: 'Requires a modern web browser with JavaScript enabled.',
    description,
    featureList: [
      'Internet speed test',
      'Download speed test',
      'Upload speed test',
      'Ping and latency test',
      'Jitter measurement',
      'Packet loss test',
      'WiFi and broadband speed test',
      'Latency under load (bufferbloat) grading',
    ],
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    isAccessibleForFree: true,
    publisher: { '@id': orgId },
    inLanguage: 'en',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [...baseGraph, ...schemas],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/png" href="/icon.png" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <meta name="apple-mobile-web-app-title" content="Meter" />
    <meta name="application-name" content="Meter Speed Test" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />
    <meta name="author" content="Meter Speed Test" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" id="theme-color-light" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" id="theme-color-dark" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Meter Speed Test" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <!-- Fonts: preconnect + the two brand faces with a system fallback -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400;500&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400;500&display=swap"
    />

    <!-- Warm up the measurement origin before the test starts -->
    <link rel="preconnect" href="https://speed.cloudflare.com" crossorigin />
    <link rel="dns-prefetch" href="https://speed.cloudflare.com" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- No-flash theme: resolve before first paint -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('meter:theme');
          var mql = window.matchMedia('(prefers-color-scheme: dark)');
          var theme = stored || (mql.matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />

    <style>
      .skip-link {
        position: fixed;
        top: 8px;
        left: 8px;
        z-index: 100;
        padding: 8px 14px;
        border-radius: var(--radius-sm);
        background: var(--primary);
        color: var(--on-primary);
        font-size: 14px;
        font-weight: 500;
        transform: translateY(-160%);
        transition: transform 0.2s var(--ease-out-quint);
      }
      .skip-link:focus-visible {
        transform: translateY(0);
      }
    </style>
  </body>
</html>
