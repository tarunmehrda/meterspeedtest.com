---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Speedometer from '../components/Speedometer.astro';
import MetricCard from '../components/MetricCard.astro';
---

<Base>
  <Nav />

  <main id="main">
    <!-- ───────────────────────── Shared-result banner ───────────────────────── -->
    <div id="shared-banner" class="shared-banner" hidden>
      <div class="container-page shared-banner__inner">
        <span class="badge">Shared result</span>
        <p id="shared-text" class="shared-banner__text"></p>
        <button type="button" id="shared-dismiss" class="btn btn-secondary btn-sm">
          Run My Own Test
        </button>
      </div>
    </div>

    <!-- ───────────────────────────────── Hero / Test ───────────────────────────────── -->
    <section class="hero" id="top">
      <div class="hero__mesh mesh" aria-hidden="true"></div>
      <div class="container-page hero__inner">
        <div class="hero__intro">
          <span class="badge hero__badge">
            <span class="dot" aria-hidden="true"></span>
            Real-time · No sign-up · Private
          </span>
          <h1 class="hero__title">
            Know exactly how fast<br />your internet <span class="text-gradient">really</span> is.
          </h1>
          <p class="hero__lead">
            Meter measures download, upload, ping, jitter, packet loss and latency under load — then
            tells you what your connection can actually handle.
          </p>
        </div>

        <div class="panel card">
          <!-- 1. Upper Metrics Block -->
          <div class="upper-results">
            <div class="upper-metric" id="upper-metric-download">
              <div class="upper-metric__label">
                <span class="upper-metric__icon download-icon">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
                </span>
                DOWNLOAD Mbps
              </div>
              <div class="upper-metric__value" id="upper-download">—</div>
            </div>
            <div class="upper-metric" id="upper-metric-upload">
              <div class="upper-metric__label">
                <span class="upper-metric__icon upload-icon">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
                </span>
                UPLOAD Mbps
              </div>
              <div class="upper-metric__value" id="upper-upload">—</div>
            </div>
          </div>

          <!-- 2. Ping Statistics Row -->
          <div class="ping-stats">
            <div class="ping-stat-header">Ping ms</div>
            <div class="ping-stat-items">
              <div class="ping-stat-item" title="Idle Latency">
                <span class="ping-stat-icon ping-stat-icon--idle">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h3l2-5 3 10 2-7 2 2h5"/></svg>
                </span>
                <span id="upper-ping-idle" class="tnum">—</span>
              </div>
              <div class="ping-stat-item" title="Download Latency (Loaded)">
                <span class="ping-stat-icon ping-stat-icon--download">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
                </span>
                <span id="upper-ping-download" class="tnum">—</span>
              </div>
              <div class="ping-stat-item" title="Upload Latency (Loaded)">
                <span class="ping-stat-icon ping-stat-icon--upload">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
                </span>
                <span id="upper-ping-upload" class="tnum">—</span>
              </div>
            </div>
          </div>

          <!-- 3. Category Rating Icons (5 dots) -->
          <div class="category-ratings">
            <div class="rating-item" data-category="web" title="Web Browsing">
              <svg class="rating-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="3" y1="9" x2="21" y2="9"></line>
                <line x1="9" y1="21" x2="9" y2="9"></line>
              </svg>
              <div class="rating-dots" id="dots-web">
                <span class="rating-dot"></span>
                <span class="rating-dot"></span>
                <span class="rating-dot"></span>
                <span class="rating-dot"></span>
                <span class="rating-dot"></span>
              </div>
            </div>
            <div class="rating-item" data-category="game" title="Gaming">
              <svg class="rating-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="6" width="20" height="12" rx="2"></rect>
                <line x1="6" y1="12" x2="10" y2="12"></line>
                <line x1="8" y1="10" x2="8" y2="14"></line>
                <circle cx="15.5" cy="12" r="1" fill="currentColor"></circle>
                <circle cx="18.5" cy="12" r="1" fill="currentColor"></circle>
              </svg>
              <div class="rating-dots" id="dots-game">
                <span class="rating-dot"></span>
                <span class="rating-dot"></span>
                <span class="rating-dot"></span>
                <span class="rating-dot"></span>
                <span class="rating-dot"></span>
              </div>
            </div>
            <div class="rating-item" data-category="video" title="Video Streaming">
              <svg class="rating-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="23 7 16 12 23 17 23 7"></polygon>
                <rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
              </svg>
              <div class="rating-dots" id="dots-video">
                <span class="rating-dot"></span>
                <span class="rating-dot"></span>
                <span class="rating-dot"></span>
                <span class="rating-dot"></span>
                <span class="rating-dot"></span>
              </div>
            </div>
            <div class="rating-item" data-category="call" title="Video Calls">
              <svg class="rating-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
              <div class="rating-dots" id="dots-call">
                <span class="rating-dot"></span>
                <span class="rating-dot"></span>
                <span class="rating-dot"></span>
                <span class="rating-dot"></span>
                <span class="rating-dot"></span>
              </div>
            </div>
          </div>

          <!-- 4. Center Speedometer -->
          <div class="panel__gauge">
            <Speedometer />
          </div>

          <!-- 5. Minimal Progress Bar -->
          <div class="progress" id="progress" aria-hidden="true">
            <div class="progress__track">
              <div class="progress__bar" id="progress-bar"></div>
            </div>
            <div class="progress__pips" style="display:none;">
              <span class="pip" data-pip="latency">Latency</span>
              <span class="pip" data-pip="download">Download</span>
              <span class="pip" data-pip="upload">Upload</span>
            </div>
          </div>

          <!-- 6. Mode selector (Quick, Balanced, Thorough) -->
          <div class="panel__mode-selector">
            <div class="segment" id="mode">
              <button type="button" data-mode="quick" aria-pressed="false">Quick</button>
              <button type="button" data-mode="balanced" aria-pressed="true" data-active="true">Balanced</button>
              <button type="button" data-mode="thorough" aria-pressed="false">Thorough</button>
            </div>
            <p class="mode__hint" id="mode-hint">~8s · balanced accuracy and data use</p>
          </div>

          <p id="status" class="panel__status" role="status" aria-live="polite">
            Ready when you are.
          </p>
        </div>

        <!-- 7. Connection / server bottom info block -->
        <div class="bottom-info" id="connection">
          <div class="bottom-info__client">
            <div class="bottom-info__text text-right">
              <div id="conn-isp" class="bottom-info__title" translate="no">Detecting…</div>
              <div id="conn-ip" class="bottom-info__sub tnum" translate="no">—</div>
            </div>
            <div class="bottom-info__icon-circle">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
            </div>
          </div>

          <div class="bottom-info__server">
            <div class="bottom-info__icon-circle">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect>
                <rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect>
                <line x1="6" y1="6" x2="6.01" y2="6"></line>
                <line x1="6" y1="18" x2="6.01" y2="18"></line>
              </svg>
            </div>
            <div class="bottom-info__text text-left">
              <div id="conn-server-name" class="bottom-info__title" translate="no">Cloudflare</div>
              <div id="conn-server-location" class="bottom-info__sub" translate="no">auto</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ───────────────────────────────── Metrics ───────────────────────────────── -->
    <section class="section" id="metrics" aria-labelledby="metrics-h">
      <div class="container-page">
        <div class="section__head">
          <span class="eyebrow">Detailed results</span>
          <h2 id="metrics-h" class="section__title">Every number that matters.</h2>
        </div>

        <div class="metrics-grid">
          <MetricCard
            metric="download"
            label="Download"
            unit="Mbps"
            icon="download"
            accent="var(--color-cyan-deep)"
            hint="How fast data reaches you"
          />
          <MetricCard
            metric="upload"
            label="Upload"
            unit="Mbps"
            icon="upload"
            accent="var(--color-brand-blue)"
            hint="How fast you can send"
          />
          <MetricCard
            metric="ping"
            label="Ping"
            unit="ms"
            icon="ping"
            accent="var(--color-violet)"
            hint="Round-trip delay, idle"
          />
          <MetricCard
            metric="jitter"
            label="Jitter"
            unit="ms"
            icon="jitter"
            accent="var(--color-amber)"
            hint="How steady the delay is"
          />
          <MetricCard
            metric="loss"
            label="Packet Loss"
            unit="%"
            icon="loss"
            accent="var(--color-red)"
            hint="Reachability of probes (est.)"
          />
          <MetricCard
            metric="loaded"
            label="Latency Under Load"
            unit="ms"
            icon="loaded"
            accent="var(--color-pink)"
            hint="Delay while the line is busy"
          />
        </div>

        <div class="graph card">
          <div class="graph__head">
            <div>
              <span class="eyebrow">Throughput over time</span>
              <p class="graph__sub">Live speed during the test — watch it ramp and settle.</p>
            </div>
            <div class="graph__legend">
              <span class="legend"><i style="background:var(--color-cyan-deep)"></i>Download</span>
              <span class="legend"><i style="background:var(--color-brand-blue)"></i>Upload</span>
            </div>
          </div>
          <canvas id="live-graph" class="graph__canvas" width="1200" height="360"></canvas>
          <p class="graph__empty" id="graph-empty">Your live throughput graph appears here.</p>
        </div>
      </div>
    </section>

    <!-- ───────────────────────────────── Insights ───────────────────────────────── -->
    <section class="section" id="insights" aria-labelledby="insights-h" hidden>
      <div class="container-page">
        <div class="section__head">
          <span class="eyebrow">What it means</span>
          <h2 id="insights-h" class="section__title">Your connection, explained.</h2>
        </div>

        <div class="insights-grid">
          <!-- Score -->
          <div class="score card">
            <div class="score__ring-wrap">
              <svg viewBox="0 0 120 120" class="score__ring" aria-hidden="true">
                <circle class="score__track" cx="60" cy="60" r="52" pathLength="100" />
                <circle
                  id="score-ring"
                  class="score__value"
                  cx="60"
                  cy="60"
                  r="52"
                  pathLength="100"
                  stroke="url(#gaugeGrad)"
                />
              </svg>
              <div class="score__center">
                <span id="score-value" class="tnum">—</span>
                <span class="score__outof">/100</span>
              </div>
            </div>
            <div class="score__meta">
              <div class="score__grade-row">
                <span id="score-grade" class="score__grade">—</span>
                <span id="score-tier" class="badge">—</span>
              </div>
              <h3 id="score-headline" class="score__headline">Run a test to score your line</h3>
              <p id="score-summary" class="score__summary">
                Meter blends speed, latency, jitter, loss and behaviour under load into one honest
                score.
              </p>
              <div id="subscores" class="subscores"></div>
            </div>
          </div>

          <!-- Bufferbloat -->
          <div class="bloat card">
            <div class="bloat__head">
              <span class="eyebrow">Bufferbloat</span>
              <span id="bloat-grade" class="grade-chip">—</span>
            </div>
            <h3 class="bloat__title">Latency under load</h3>
            <p id="bloat-detail" class="bloat__detail">
              We re-measure ping while saturating your line. Big jumps mean calls and games stutter
              during downloads.
            </p>
            <div class="bloat__bars">
              <div class="bloat__bar">
                <span>Idle</span>
                <div class="bar"><i id="bar-idle"></i></div>
                <span class="tnum" id="bloat-idle">—</span>
              </div>
              <div class="bloat__bar">
                <span>Loaded</span>
                <div class="bar"><i id="bar-loaded"></i></div>
                <span class="tnum" id="bloat-loaded">—</span>
              </div>
            </div>
          </div>

          <!-- Capabilities -->
          <div class="caps card">
            <span class="eyebrow">What your line can do</span>
            <ul id="capabilities" class="caps__list" aria-live="polite"></ul>
          </div>
        </div>

        <!-- Share / export -->
        <div id="share-actions" class="share">
          <span class="share__label">Share or save your result</span>
          <div class="share__btns">
            <button type="button" id="btn-share" class="btn btn-secondary btn-sm" hidden>
              Share
            </button>
            <button type="button" id="btn-copy" class="btn btn-secondary btn-sm">Copy Link</button>
            <button type="button" id="btn-png" class="btn btn-secondary btn-sm">
              Download Image
            </button>
            <button type="button" id="btn-json" class="btn btn-secondary btn-sm">
              Export JSON
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- ───────────────────────────────── History ───────────────────────────────── -->
    <section class="section" id="history" aria-labelledby="history-h">
      <div class="container-page">
        <div class="section__head section__head--row">
          <div>
            <span class="eyebrow">Your history</span>
            <h2 id="history-h" class="section__title">Track it over time.</h2>
          </div>
          <div class="history__actions">
            <button type="button" id="btn-export-csv" class="btn btn-ghost btn-sm">Export CSV</button>
            <button type="button" id="btn-clear-history" class="btn btn-ghost btn-sm">Clear</button>
          </div>
        </div>

        <div class="history card">
          <div class="history__trend" id="history-trend-wrap" hidden>
            <div class="history__trend-head">
              <span class="eyebrow">Download trend</span>
              <span class="history__trend-note" id="history-trend-note"></span>
            </div>
            <svg
              id="history-trend"
              viewBox="0 0 600 120"
              preserveAspectRatio="none"
              class="history__spark"
              aria-hidden="true"></svg>
          </div>
          
          <div class="history__header-row" id="history-header" hidden>
            <span class="text-left font-semibold uppercase tracking-wider text-[11px] text-faint">Date & ISP</span>
            <span class="text-center font-semibold uppercase tracking-wider text-[11px] text-faint">Download</span>
            <span class="text-center font-semibold uppercase tracking-wider text-[11px] text-faint">Upload</span>
            <span class="text-center font-semibold uppercase tracking-wider text-[11px] text-faint history__header-ping">Ping</span>
            <span></span>
          </div>
          
          <ul id="history-list" class="history__list"></ul>
          <div id="history-empty" class="history__empty-state">
            <div class="history__empty-icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <h3 class="history__empty-title">No speed test history</h3>
            <p class="history__empty-desc">
              Your test results will be stored locally on this device so you can track performance variations over time.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ───────────────────────────────── Why Meter ───────────────────────────────── -->
    <section class="section" aria-labelledby="why-h">
      <div class="container-page">
        <div class="section__head">
          <span class="eyebrow">Why Meter</span>
          <h2 id="why-h" class="section__title">A speed test that respects your time.</h2>
        </div>
        <div class="features">
          <article class="feature card-soft">
            <h3 class="feature__title">Latency under load</h3>
            <p class="feature__body">
              Most tests report ping when your line is idle — useless when it matters. Meter measures
              delay <em>while</em> saturating the connection, the way real apps stress it.
            </p>
          </article>
          <article class="feature card-soft">
            <h3 class="feature__title">Answers, not just numbers</h3>
            <p class="feature__body">
              A raw Mbps figure means little. Meter translates it into “can I run 3 4K streams” and
              “will my calls hold up,” with a single honest score.
            </p>
          </article>
          <article class="feature card-soft">
            <h3 class="feature__title">Private by default</h3>
            <p class="feature__body">
              No account, no tracking wall, no results uploaded to a leaderboard. History lives in
              your browser and you export it if you want it.
            </p>
          </article>
          <article class="feature card-soft">
            <h3 class="feature__title">Fast and light</h3>
            <p class="feature__body">
              A static, zero-framework page that loads instantly and starts testing on tap — built
              to be quicker than the tools it learns from.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- ───────────────────────────────── FAQ ───────────────────────────────── -->
    <section class="section" id="faq" aria-labelledby="faq-h">
      <div class="container-page container-narrow">
        <div class="section__head">
          <span class="eyebrow">Good to know</span>
          <h2 id="faq-h" class="section__title">Questions, answered.</h2>
        </div>
        <div class="faq">
          <details class="faq__item">
            <summary class="faq__q">How does Meter measure my speed?</summary>
            <div class="faq__a">
              Meter runs entirely in your browser. It streams data to and from Cloudflare’s global
              edge network — the same infrastructure that serves a large share of the web — using
              several parallel connections to fully saturate your line, then aggregates the stable
              portion of each run.
            </div>
          </details>
          <details class="faq__item">
            <summary class="faq__q">What is latency under load (bufferbloat)?</summary>
            <div class="faq__a">
              It’s how much your ping rises when the connection is busy. A line can look fast yet feel
              terrible on calls because latency balloons during uploads or downloads. Meter grades
              this A+ to F so you can spot it.
            </div>
          </details>
          <details class="faq__item">
            <summary class="faq__q">Why is my result different from my plan’s speed?</summary>
            <div class="faq__a">
              Wi-Fi, the device you’re on, time of day, VPNs and background apps all cost speed.
              For the truest number, test over a wired connection with other devices idle, and run it
              a few times.
            </div>
          </details>
          <details class="faq__item">
            <summary class="faq__q">Is packet loss really measured in a browser?</summary>
            <div class="faq__a">
              Browsers can’t see raw packets, so Meter estimates loss from probes that fail or time
              out during the test. Treat it as a stability signal rather than a lab-grade figure —
              that’s why it’s labelled an estimate.
            </div>
          </details>
          <details class="faq__item">
            <summary class="faq__q">How much data does a test use?</summary>
            <div class="faq__a">
              Meter stops each phase the moment your speed stabilises, so a Balanced run usually
              finishes in about ten seconds and moves 100–400 MB depending on how fast your line
              is. On a metered or mobile plan, choose Quick.
            </div>
          </details>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<script>
  import '../scripts/app';
</script>

<style>
  /* ── Hero ─────────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    padding-top: 40px;
  }
  .hero__mesh {
    position: absolute;
    inset: -20% -10% auto -10%;
    height: 620px;
    filter: blur(60px) saturate(130%);
    opacity: 0.5;
    z-index: 0;
    pointer-events: none;
  }
  :global([data-theme='dark']) .hero__mesh {
    opacity: 0.36;
  }
  .hero__inner {
    position: relative;
    z-index: 1;
  }
  .hero__intro {
    text-align: center;
    max-width: 720px;
    margin: 12px auto 0;
  }
  .hero__badge {
    margin-bottom: 20px;
  }
  .hero__badge .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-green);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-green) 25%, transparent);
  }
  .hero__title {
    font-size: clamp(34px, 6vw, 56px);
    font-weight: 600;
    line-height: 1.03;
    letter-spacing: -0.035em;
    color: var(--text);
  }
  .hero__lead {
    margin: 20px auto 0;
    max-width: 60ch;
    font-size: clamp(16px, 2.2vw, 19px);
    line-height: 1.55;
    color: var(--text-muted);
    text-wrap: pretty;
  }

  /* ── Test panel ───────────────────────────────────── */
  .panel {
    margin: 40px auto 0;
    max-width: 480px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    border-radius: var(--radius-xl);
    border: 1px solid var(--hairline);
    background: radial-gradient(100% 100% at 50% 0%, var(--surface) 0%, var(--surface-soft) 100%);
    box-shadow: var(--shadow-3);
  }
  .panel__gauge {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-block: 8px;
  }
  
  /* Upper Results Row */
  .upper-results {
    display: flex;
    justify-content: space-between;
    width: 100%;
    border-bottom: 1.5px solid var(--hairline);
    padding-bottom: 16px;
    margin-bottom: 14px;
  }
  .upper-metric {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
  }
  .upper-metric__label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 700;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .upper-metric__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 50%;
  }
  .upper-metric__icon.download-icon {
    color: var(--color-cyan-deep);
    background: color-mix(in srgb, var(--color-cyan-deep) 15%, transparent);
  }
  .upper-metric__icon.upload-icon {
    color: var(--color-brand-blue);
    background: color-mix(in srgb, var(--color-brand-blue) 15%, transparent);
  }
  .upper-metric__value {
    font-size: 38px;
    font-weight: 300;
    font-family: var(--font-sans);
    color: var(--text);
    margin-top: 4px;
    line-height: 1;
    min-height: 38px;
  }
  
  /* Ping Statistics Row */
  .ping-stats {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    margin-bottom: 16px;
  }
  .ping-stat-header {
    font-size: 11px;
    font-weight: 700;
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .ping-stat-items {
    display: flex;
    gap: 24px;
    justify-content: center;
  }
  .ping-stat-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
  }
  .ping-stat-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
  }
  .ping-stat-icon--idle {
    color: var(--color-amber);
    background: color-mix(in srgb, var(--color-amber) 15%, transparent);
  }
  .ping-stat-icon--download {
    color: var(--color-cyan-deep);
    background: color-mix(in srgb, var(--color-cyan-deep) 15%, transparent);
  }
  .ping-stat-icon--upload {
    color: var(--color-brand-blue);
    background: color-mix(in srgb, var(--color-brand-blue) 15%, transparent);
  }
  
  /* Category Ratings Row */
  .category-ratings {
    display: flex;
    justify-content: space-around;
    width: 100%;
    border-bottom: 1.5px solid var(--hairline);
    padding-bottom: 14px;
    margin-bottom: 12px;
  }
  .rating-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    flex: 1;
  }
  .rating-icon {
    color: var(--text-faint);
    transition: color 0.3s;
  }
  .rating-dots {
    display: flex;
    gap: 4px;
  }
  .rating-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: var(--track);
    transition: background-color 0.3s;
  }
  .rating-dot--active {
    background-color: var(--color-green);
    box-shadow: 0 0 4px var(--color-green);
  }
  
  /* Mode Selector inside panel */
  .panel__mode-selector {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    margin-top: 14px;
  }
  .mode__hint {
    font-size: 11px;
    color: var(--text-faint);
    font-family: var(--font-mono);
  }

  .progress {
    width: 100%;
    margin-top: 12px;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .progress[data-visible='true'] {
    opacity: 1;
  }
  .progress__track {
    height: 4px;
    border-radius: var(--radius-pill);
    background: var(--track);
    overflow: hidden;
  }
  .progress__bar {
    position: relative;
    overflow: hidden;
    height: 100%;
    width: 0%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--color-cyan), var(--color-brand-blue), var(--color-violet));
    transition: width 0.25s var(--ease-out-quint);
  }
  /* Light sweep across the filled bar — transform-only, compositor-friendly. */
  .progress__bar::after {
    content: '';
    position: absolute;
    inset: 0;
    transform: translateX(-100%);
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.55), transparent);
    animation: shimmer 1.5s ease-in-out infinite;
  }
  @keyframes shimmer {
    to {
      transform: translateX(100%);
    }
  }
  .panel__status {
    margin-top: 14px;
    font-size: 13px;
    color: var(--text-muted);
    text-align: center;
    min-height: 20px;
    text-wrap: balance;
  }

  /* ── Bottom Info block ─────────────────────────────── */
  .bottom-info {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    max-width: 500px;
    margin: 24px auto 0;
    padding: 0;
    background: transparent;
    border: none;
    box-shadow: none;
    gap: 16px;
  }
  .bottom-info__client,
  .bottom-info__server {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    min-width: 0;
  }
  .bottom-info__client {
    justify-content: flex-end;
  }
  .bottom-info__server {
    justify-content: flex-start;
  }
  .bottom-info__text {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .bottom-info__title {
    font-size: 15px;
    font-weight: 500;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.25;
  }
  .bottom-info__sub {
    font-size: 12.5px;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-top: 2px;
    line-height: 1.2;
  }
  .bottom-info__icon-circle {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid var(--hairline-strongest);
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text);
    flex: none;
  }

  /* ── Sections ─────────────────────────────────────── */
  .section {
    padding-top: 72px;
  }
  .section__head {
    margin-bottom: 28px;
  }
  .section__head--row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .section__title {
    margin-top: 8px;
    font-size: clamp(24px, 4vw, 34px);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--text);
  }
  .container-narrow {
    max-width: 760px;
  }

  /* ── Metrics grid ─────────────────────────────────── */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  @media (min-width: 720px) {
    .metrics-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Live graph ───────────────────────────────────── */
  .graph {
    margin-top: 16px;
    padding: 20px;
    position: relative;
  }
  .graph__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
  }
  .graph__sub {
    margin-top: 4px;
    font-size: 13px;
    color: var(--text-faint);
  }
  .graph__legend {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .legend {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12.5px;
    color: var(--text-muted);
  }
  .legend i {
    width: 10px;
    height: 10px;
    border-radius: 3px;
  }
  .graph__canvas {
    width: 100%;
    height: auto;
    aspect-ratio: 1200 / 360;
    display: block;
  }
  .graph__empty {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 46%;
    text-align: center;
    font-size: 13px;
    color: var(--text-faint);
    pointer-events: none;
  }

  /* ── Insights ─────────────────────────────────────── */
  /* Staggered entrance each time a fresh result lands. */
  #insights.insights--enter .insights-grid > .card,
  #insights.insights--enter .share {
    animation: riseIn 0.55s var(--ease-out-quint) both;
  }
  #insights.insights--enter .insights-grid > .card:nth-child(2) {
    animation-delay: 90ms;
  }
  #insights.insights--enter .insights-grid > .card:nth-child(3) {
    animation-delay: 180ms;
  }
  #insights.insights--enter .share {
    animation-delay: 260ms;
  }
  @keyframes riseIn {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .insights-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }
  @media (min-width: 880px) {
    .insights-grid {
      grid-template-columns: 1.5fr 1fr;
      grid-auto-rows: auto;
    }
    .caps {
      grid-column: 1 / -1;
    }
  }
  .score {
    padding: 24px;
    display: flex;
    gap: 24px;
    align-items: center;
    flex-wrap: wrap;
  }
  .score__ring-wrap {
    position: relative;
    width: 132px;
    height: 132px;
    flex: none;
  }
  .score__ring {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }
  .score__track {
    fill: none;
    stroke: var(--track);
    stroke-width: 9;
  }
  .score__value {
    fill: none;
    stroke-width: 9;
    stroke-linecap: round;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    transition: stroke-dashoffset 0.9s var(--ease-out-quint);
  }
  .score__center {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  #score-value {
    font-size: 40px;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--text);
  }
  .score__outof {
    font-size: 12px;
    color: var(--text-faint);
    margin-top: 2px;
  }
  .score__meta {
    flex: 1;
    min-width: 220px;
  }
  .score__grade-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }
  .score__grade {
    font-size: 22px;
    font-weight: 600;
    color: var(--text);
  }
  .score__headline {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text);
  }
  .score__summary {
    margin-top: 6px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-muted);
    text-wrap: pretty;
  }
  .subscores {
    margin-top: 16px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px 18px;
  }
  .subscore {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .subscore__top {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--text-muted);
  }
  .subscore__bar {
    height: 5px;
    border-radius: var(--radius-pill);
    background: var(--track);
    overflow: hidden;
  }
  .subscore__fill {
    height: 100%;
    border-radius: inherit;
    width: 0%;
    transition: width 0.8s var(--ease-out-quint);
  }

  .bloat {
    padding: 24px;
    display: flex;
    flex-direction: column;
  }
  .bloat__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }
  .grade-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 34px;
    padding-inline: 10px;
    border-radius: var(--radius-md);
    font-size: 18px;
    font-weight: 600;
    background: var(--surface-soft-2);
    color: var(--text);
  }
  .bloat__title {
    font-size: 17px;
    font-weight: 600;
    color: var(--text);
  }
  .bloat__detail {
    margin-top: 6px;
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--text-muted);
    flex: 1;
    text-wrap: pretty;
  }
  .bloat__bars {
    margin-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .bloat__bar {
    display: grid;
    grid-template-columns: 52px 1fr 56px;
    align-items: center;
    gap: 10px;
    font-size: 12.5px;
    color: var(--text-muted);
  }
  .bloat__bar .bar {
    height: 8px;
    border-radius: var(--radius-pill);
    background: var(--track);
    overflow: hidden;
  }
  .bloat__bar .bar i {
    display: block;
    height: 100%;
    width: 0%;
    border-radius: inherit;
    transition: width 0.8s var(--ease-out-quint), background-color 0.3s;
  }
  .bloat__bar .tnum {
    text-align: right;
    color: var(--text);
    font-weight: 500;
  }

  .caps {
    padding: 24px;
  }
  .caps__list {
    margin-top: 16px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2px;
  }
  @media (min-width: 640px) {
    .caps__list {
      grid-template-columns: repeat(2, 1fr);
      gap: 2px 32px;
    }
  }
  @media (min-width: 980px) {
    .caps__list {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .cap {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--hairline);
  }
  .cap__dot {
    margin-top: 4px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex: none;
  }
  .cap__label {
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
  }
  .cap__detail {
    font-size: 12.5px;
    color: var(--text-faint);
    line-height: 1.45;
    margin-top: 1px;
  }

  /* ── Share ────────────────────────────────────────── */
  .share {
    margin-top: 20px;
    padding: 18px 20px;
    border: 1px dashed var(--hairline-strong);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    flex-wrap: wrap;
  }
  .share__label {
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
  }
  .share__btns {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  /* ── History ──────────────────────────────────────── */
  .history {
    padding: 0;
    overflow: hidden;
  }
  .history__actions {
    display: flex;
    gap: 8px;
  }
  .history__trend {
    padding: 20px;
    background: radial-gradient(100% 100% at 50% 0%, var(--surface-soft) 0%, var(--surface) 100%);
    border-bottom: 1px solid var(--hairline);
  }
  .history__trend-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }
  .history__trend-note {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-cyan-deep);
  }
  .history__spark {
    width: 100%;
    height: 100px;
    display: block;
    filter: drop-shadow(0 2px 8px rgba(41, 188, 155, 0.15));
  }
  
  /* Table Header */
  .history__header-row {
    display: grid;
    grid-template-columns: 1.3fr repeat(3, 1fr) auto;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
    background: var(--surface-soft-2);
    border-bottom: 1px solid var(--hairline);
  }
  
  .history__list {
    display: flex;
    flex-direction: column;
  }
  .history__row {
    display: grid;
    grid-template-columns: 1.3fr repeat(3, 1fr) auto;
    align-items: center;
    gap: 12px;
    padding: 14px 20px;
    border-bottom: 1px solid var(--hairline);
    transition: background-color 0.2s var(--ease-out-quint);
  }
  .history__row:hover {
    background-color: var(--surface-soft);
  }
  .history__row:last-child {
    border-bottom: none;
  }
  
  .history__when {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .history__date {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--text);
  }
  .history__isp {
    font-size: 11.5px;
    color: var(--text-faint);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  /* Modern Badges for History list */
  .history-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: 500;
    white-space: nowrap;
  }
  .history-badge--download {
    color: var(--color-cyan-deep);
    background: color-mix(in srgb, var(--color-cyan-deep) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-cyan-deep) 20%, transparent);
  }
  .history-badge--upload {
    color: var(--color-brand-blue);
    background: color-mix(in srgb, var(--color-brand-blue) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-brand-blue) 20%, transparent);
  }
  .history-badge--ping {
    color: var(--color-amber);
    background: color-mix(in srgb, var(--color-amber) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-amber) 20%, transparent);
  }
  
  .history__del {
    color: var(--text-faint);
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: 1px solid transparent;
    transition: all 0.2s var(--ease-out-quint);
    background: transparent;
  }
  .history__del:hover {
    color: var(--color-red);
    background: color-mix(in srgb, var(--color-red) 12%, transparent);
    border-color: color-mix(in srgb, var(--color-red) 20%, transparent);
  }
  
  /* Empty State UI */
  .history__empty-state {
    padding: 48px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    max-width: 380px;
    margin-inline: auto;
  }
  .history__empty-icon-wrap {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--surface-soft-2);
    border: 1px dashed var(--hairline-strongest);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-faint);
    margin-bottom: 14px;
  }
  .history__empty-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 6px;
  }
  .history__empty-desc {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.5;
  }
  
  @media (max-width: 620px) {
    .history__header-row,
    .history__row {
      grid-template-columns: 1.4fr repeat(2, 1fr) auto;
      gap: 8px;
      padding-inline: 12px;
    }
    .history__header-ping,
    .history__stat-ping {
      display: none !important;
    }
    .history-badge {
      padding: 3px 8px;
      font-size: 12px;
    }
  }

  /* ── Features ─────────────────────────────────────── */
  .features {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }
  @media (min-width: 720px) {
    .features {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .feature {
    padding: 22px;
  }
  .feature__title {
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text);
  }
  .feature__body {
    margin-top: 8px;
    font-size: 14px;
    line-height: 1.55;
    color: var(--text-muted);
    text-wrap: pretty;
  }
  .feature__body em {
    font-style: italic;
    color: var(--text);
  }

  /* ── FAQ ──────────────────────────────────────────── */
  .faq {
    display: flex;
    flex-direction: column;
  }
  .faq__item {
    border-bottom: 1px solid var(--hairline);
  }
  .faq__q {
    padding: 18px 0;
    font-size: 16px;
    font-weight: 500;
    color: var(--text);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .faq__q::-webkit-details-marker {
    display: none;
  }
  .faq__q::after {
    content: '';
    width: 10px;
    height: 10px;
    border-right: 2px solid var(--text-faint);
    border-bottom: 2px solid var(--text-faint);
    transform: rotate(45deg);
    transition: transform 0.2s;
    flex: none;
  }
  .faq__item[open] .faq__q::after {
    transform: rotate(-135deg);
  }
  .faq__a {
    padding: 0 0 20px;
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 68ch;
    text-wrap: pretty;
  }

  /* ── Shared banner ────────────────────────────────── */
  .shared-banner {
    background: var(--surface-soft-2);
    border-bottom: 1px solid var(--hairline);
