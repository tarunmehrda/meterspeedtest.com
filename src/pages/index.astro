              </div>
              <h3 id="score-headline" class="score__headline">Run a test to score your line</h3>
              <p id="score-summary" class="score__summary">
                Meter blends speed, latency, jitter, loss and behaviour under load into one honest
                score.
              </p>
              <div id="subscores" class="subscores"></div>
            </div>
          </div>

          <!-- Bufferbloat -->
          <div class="bloat card">
            <div class="bloat__head">
              <span class="eyebrow">Bufferbloat</span>
              <span id="bloat-grade" class="grade-chip">—</span>
            </div>
            <h3 class="bloat__title">Latency under load</h3>
            <p id="bloat-detail" class="bloat__detail">
              We re-measure ping while saturating your line. Big jumps mean calls and games stutter
              during downloads.
            </p>
            <div class="bloat__bars">
              <div class="bloat__bar">
                <span>Idle</span>
                <div class="bar"><i id="bar-idle"></i></div>
                <span class="tnum" id="bloat-idle">—</span>
